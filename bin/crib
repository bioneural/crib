#!/usr/bin/env ruby
# frozen_string_literal: true

# crib — memory storage and retrieval for AI agents
# https://github.com/bioneural/crib
# MIT License — Copyright (c) 2026 Kerry Ivan Kurian
#
# A single-file memory system: fact triples, full-text search, and vector
# embeddings in one SQLite database. Write stores text and extracts triples.
# Retrieve queries all channels and returns what's relevant for a given prompt.
# Maintain consolidates memories into cross-cutting insights and discovers
# connections between entries.
#
# Subcommands:
#
#   crib write     Store text and extracted fact triples
#   crib retrieve  Query memory and return relevant context
#   crib hints     Return lightweight topic-level nudges for injection (stdin)
#   crib init      Initialize the database (run automatically on first write)
#   crib doctor    Check all prerequisites and report status (JSON on stdout)
#   crib maintain  Run maintenance (correction linking, contradiction detection,
#                  staleness tracking, decay if enabled, generative consolidation,
#                  connection discovery)
#                  --dry-run  Report what would change without modifying data
#
# Usage:
#   echo "Chose SQLite for storage" | bin/crib write
#   echo "type=decision Chose SQLite" | bin/crib write
#   echo "what database did we choose?" | bin/crib retrieve
#   echo "what database did we choose?" | bin/crib hints
#   bin/crib init
#   bin/crib doctor
#   bin/crib maintain
#
# Environment:
#   ANTHROPIC_API_KEY  Required for triple extraction, reranking, and consolidation.
#   VOYAGE_API_KEY     Required for vector embeddings.
#   CRIB_DB            Path to the SQLite database file.
#                      Default: .state/crib/crib.db (relative to cwd)
#
# Output:
#   write     — status on stderr, nothing on stdout
#   retrieve  — <system-reminder>...</system-reminder> on stdout (empty = nothing relevant)
#   hints     — plain text on stdout, one hint per line (empty = nothing relevant)
#   init      — status on stderr
#   maintain  — JSON on stdout: {"contradictions_found":N,"corrections_linked":N,"stale_count":N,"supersessions_applied":N,"decayed_count":N,"consolidations_generated":N,"connections_discovered":N,"dry_run":bool,"min_decay_score":F}
#
# Dependencies: Ruby stdlib plus the sqlite3 gem. No other gems.
#               External: sqlite-vec (extension), ANTHROPIC_API_KEY, VOYAGE_API_KEY
#
# Behavior:
#   write:
#     1. Read text from stdin
#     2. Parse optional type= prefix (fact, lesson, directive)
#     3. Initialize database if needed
#     4. Store entry with FTS5 indexing
#     5. Extract fact triples via Anthropic API
#     6. Store entities and relations (consolidation-on-write: supersedes stale facts)
#     7. Generate embedding via Voyage API and store in vec0 table
#
#   retrieve:
#     1. Read prompt from stdin
#     2. Extract keywords
#     3. Query three channels: triples (SQL), full-text (FTS5), vectors (sqlite-vec)
#     4. Merge and deduplicate
#     5. Rerank with Anthropic API (binary yes/no scoring, parallel)
#     6. Wrap in <system-reminder> tags and output to stdout
#     7. Update last_retrieved_at on returned entries
#     8. Exit 0 always (fail-open)
#
#   maintain:
#     1. Detect contradictions among recent entries via FTS5 similarity + classify
#     2. Link corrections to their originals via vector search
#     3. Report stale entries (not retrieved in 30+ days)
#     4. Generative consolidation: batch unconsolidated entries, call Anthropic
#        to synthesize cross-cutting insights and discover connections
#     5. Output JSON summary to stdout
#     6. Exit 0 always (fail-open)
#
# Schema: see the SCHEMA constant below or the README.

require 'json'
require 'open3'
require 'net/http'
require 'fileutils'
require 'uri'
require 'time'
require 'sqlite3'

SPILL_HOME = ENV['SPILL_HOME'] || File.expand_path('../../spill', __dir__)
LOG_LEVEL = 'info'
if File.directory?(SPILL_HOME)
  require File.join(SPILL_HOME, 'lib', 'spill')
  Spill.configure(tool: 'crib', level: LOG_LEVEL)
end

SCREEN_HOME = ENV['SCREEN_HOME'] || File.expand_path('../../screen', __dir__)

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

DB_PATH = ENV.fetch('CRIB_DB') { File.join(Dir.pwd, '.state', 'crib', 'crib.db') }
ANTHROPIC_API_KEY = ENV['ANTHROPIC_API_KEY']
ANTHROPIC_API_BASE = 'https://api.anthropic.com'
ANTHROPIC_MODEL = 'claude-haiku-4-5-20251001'
VOYAGE_API_KEY = ENV['VOYAGE_API_KEY']
VOYAGE_API_BASE = 'https://api.voyageai.com'
VOYAGE_MODEL = 'voyage-4-large'
EMBEDDING_DIM = 1024
DISTANCE_METRIC = 'cosine'
VECTOR_DISTANCE_THRESHOLD = 0.5
RRF_K = 60
RRF_LIMIT = 20
RERANK_LIMIT = 10
RERANK_THRESHOLD = 0.5
FTS_CANDIDATES = 20
VECTOR_CANDIDATES = 20

# sqlite-vec extension: auto-detect via Python package.
VEC_EXTENSION = begin
  detected, status = Open3.capture2('python3', '-c', 'import sqlite_vec; print(sqlite_vec.loadable_path())')
  status.success? ? detected.strip : 'vec0'
rescue
  'vec0'
end
TOKEN_BUDGET = 2000
CHAR_BUDGET = TOKEN_BUDGET * 4

STALENESS_DAYS = 30
CONNECTION_EXPANSION_LIMIT = 3
CONSOLIDATION_BATCH_SIZE = 12
CONSOLIDATION_MAX_BATCHES = 3
CONSOLIDATION_MIN_ENTRIES = 3
HINTS_CAP = 5
PREF_LIMIT = 5

KNOWLEDGE_DIR = File.join(File.dirname(DB_PATH), 'knowledge')

DECAY_ENABLED = true

HALF_LIFE = {
  'fact'      => 30,
  'lesson'    => 30,
  'directive' => 180,
}.freeze

DECAY_ARCHIVE_THRESHOLD = 0.05
RETRIEVAL_BOOST         = 0.15
GRACE_PERIOD_DAYS       = 7

# ---------------------------------------------------------------------------
# Schema
# ---------------------------------------------------------------------------

SCHEMA = <<~SQL
  -- Fact triples (structured recall)
  CREATE TABLE IF NOT EXISTS entities (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,
    type TEXT NOT NULL,
    created_at TEXT DEFAULT (datetime('now'))
  );

  CREATE TABLE IF NOT EXISTS relations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    subject_id INTEGER NOT NULL REFERENCES entities(id),
    predicate TEXT NOT NULL,
    object_id INTEGER NOT NULL REFERENCES entities(id),
    valid_from TEXT DEFAULT (datetime('now')),
    valid_until TEXT,
    created_at TEXT DEFAULT (datetime('now'))
  );

  CREATE TABLE IF NOT EXISTS sources (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    relation_id INTEGER NOT NULL REFERENCES relations(id),
    raw_text TEXT NOT NULL,
    timestamp TEXT DEFAULT (datetime('now'))
  );

  -- Full-text entries (unstructured recall)
  CREATE TABLE IF NOT EXISTS entries (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    type TEXT NOT NULL,
    content TEXT NOT NULL,
    embedding BLOB,
    created_at TEXT DEFAULT (datetime('now')),
    source TEXT NOT NULL DEFAULT 'agent'
  );

  CREATE VIRTUAL TABLE IF NOT EXISTS entries_fts USING fts5(
    content,
    content='entries',
    content_rowid='id',
    tokenize='porter unicode61'
  );

  CREATE TRIGGER IF NOT EXISTS entries_ai AFTER INSERT ON entries BEGIN
    INSERT INTO entries_fts(rowid, content) VALUES (new.id, new.content);
  END;

  CREATE TRIGGER IF NOT EXISTS entries_ad AFTER DELETE ON entries BEGIN
    INSERT INTO entries_fts(entries_fts, rowid, content) VALUES('delete', old.id, old.content);
  END;

  CREATE TRIGGER IF NOT EXISTS entries_au AFTER UPDATE ON entries BEGIN
    INSERT INTO entries_fts(entries_fts, rowid, content) VALUES('delete', old.id, old.content);
    INSERT INTO entries_fts(rowid, content) VALUES (new.id, new.content);
  END;
SQL

CONSOLIDATION_SCHEMA = <<~SQL
  CREATE TABLE IF NOT EXISTS consolidations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    content TEXT NOT NULL,
    source_entry_ids TEXT NOT NULL,
    created_at TEXT DEFAULT (datetime('now')),
    superseded_by INTEGER
  );

  CREATE TABLE IF NOT EXISTS connections (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    entry_id_a INTEGER NOT NULL,
    entry_id_b INTEGER NOT NULL,
    relationship TEXT NOT NULL,
    strength REAL DEFAULT 1.0,
    created_at TEXT DEFAULT (datetime('now')),
    UNIQUE(entry_id_a, entry_id_b)
  );
SQL

# Vec0 table must be created separately because it requires the sqlite-vec extension
VEC_SCHEMA = <<~SQL
  CREATE VIRTUAL TABLE IF NOT EXISTS entries_vec USING vec0(
    embedding float[#{EMBEDDING_DIM}] distance_metric=#{DISTANCE_METRIC}
  );
SQL

# ---------------------------------------------------------------------------
# Database connection
# ---------------------------------------------------------------------------

def open_db
  spill_log(:debug, "opening database at #{DB_PATH}")
  db = SQLite3::Database.new(DB_PATH)
  db.busy_timeout = 5000
  db.execute('PRAGMA journal_mode=WAL')
  db.results_as_hash = true
  db
end

def open_db_vec
  db = open_db
  db.enable_load_extension(true)
  db.load_extension(VEC_EXTENSION)
  db.enable_load_extension(false)
  db
rescue SQLite3::Exception => e
  spill_log(:error, "sqlite-vec load error: #{e.message}")
  nil
end

# ---------------------------------------------------------------------------
# Shared helpers
# ---------------------------------------------------------------------------

LEVEL_RANK = { 'debug' => 0, 'info' => 1, 'warn' => 2, 'error' => 3 }.freeze

def spill_log(level, msg, **ctx)
  if defined?(Spill)
    Spill.send(level, msg, **ctx)
  else
    return if LEVEL_RANK.fetch(level.to_s, 0) < LEVEL_RANK.fetch(LOG_LEVEL, 2)
    $stderr.puts("crib: #{msg}")
  end
end

def sql_exec(db, query, params = [])
  db.execute(query, params)
rescue SQLite3::Exception => e
  spill_log(:error, "sqlite3 error: #{e.message}")
  nil
end

def sql_query(db, query, params = [])
  db.execute(query, params).map(&:dup)
rescue SQLite3::Exception => e
  spill_log(:error, "sqlite3 error: #{e.message}")
  []
end

# vec0 virtual tables report fewer columns than a SELECT rowid, distance
# query actually returns, which breaks results_as_hash. Query with hash
# mode off and zip the column names manually.
def sql_query_vec(db, query, columns, params = [])
  saved = db.results_as_hash
  db.results_as_hash = false
  rows = db.execute(query, params)
  rows.map { |row| columns.zip(row).to_h }
rescue SQLite3::Exception => e
  spill_log(:error, "sqlite3 error: #{e.message}")
  []
ensure
  db.results_as_hash = saved
end

def sql_insert_returning_id(db, query, params = [])
  db.execute(query, params)
  db.last_insert_row_id
rescue SQLite3::Exception => e
  spill_log(:error, "sqlite3 error: #{e.message}")
  nil
end

def call_anthropic(prompt, max_tokens: 256)
  unless ANTHROPIC_API_KEY
    spill_log(:warn, 'ANTHROPIC_API_KEY not set')
    return nil
  end

  uri = URI("#{ANTHROPIC_API_BASE}/v1/messages")
  req = Net::HTTP::Post.new(uri)
  req['Content-Type'] = 'application/json'
  req['x-api-key'] = ANTHROPIC_API_KEY
  req['anthropic-version'] = '2023-06-01'

  req.body = JSON.generate({
    model: ANTHROPIC_MODEL,
    max_tokens: max_tokens,
    temperature: 0,
    messages: [{ role: 'user', content: prompt }]
  })

  http = Net::HTTP.new(uri.hostname, uri.port)
  http.use_ssl = uri.scheme == 'https'
  http.read_timeout = 30
  response = http.request(req)

  unless response.is_a?(Net::HTTPSuccess)
    spill_log(:error, "anthropic error: HTTP #{response.code}")
    return nil
  end

  data = JSON.parse(response.body)
  data.dig('content', 0, 'text')
rescue Errno::ECONNREFUSED
  spill_log(:warn, 'anthropic API unreachable (connection refused)')
  nil
rescue => e
  spill_log(:error, "anthropic failed: #{e.message}")
  nil
end

def db_exists?
  File.exist?(DB_PATH)
end

def ensure_db_dir
  dir = File.dirname(DB_PATH)
  FileUtils.mkdir_p(dir) unless Dir.exist?(dir)
end

def has_column?(db, table, column)
  cols = db.table_info(table)
  cols.any? { |c| c['name'] == column }
rescue SQLite3::Exception
  false
end

def run_migrations(db)
  unless has_column?(db, 'entries', 'last_retrieved_at')
    db.execute("ALTER TABLE entries ADD COLUMN last_retrieved_at TEXT;")
  end
  unless has_column?(db, 'entries', 'superseded_by')
    db.execute("ALTER TABLE entries ADD COLUMN superseded_by INTEGER;")
  end
  unless has_column?(db, 'entries', 'retrieval_count')
    db.execute("ALTER TABLE entries ADD COLUMN retrieval_count INTEGER DEFAULT 0")
  end
  unless has_column?(db, 'entries', 'source')
    db.execute("ALTER TABLE entries ADD COLUMN source TEXT NOT NULL DEFAULT 'agent'")
  end
  unless has_column?(db, 'entries', 'consolidated_at')
    db.execute("ALTER TABLE entries ADD COLUMN consolidated_at TEXT")
  end
rescue SQLite3::Exception => e
  spill_log(:error, "migration error: #{e.message}")
end

def init_db
  ensure_db_dir
  db = open_db
  db.execute_batch(SCHEMA)
  db.execute_batch(CONSOLIDATION_SCHEMA)
  run_migrations(db)
  db.close

  vec_db = open_db_vec
  if vec_db
    vec_db.execute_batch(VEC_SCHEMA)
    vec_db.close
  end
end

def voyage_embed(text)
  spill_log(:debug, "embedding #{text.length} chars with #{VOYAGE_MODEL}")
  unless VOYAGE_API_KEY
    spill_log(:warn, 'VOYAGE_API_KEY not set')
    return nil
  end

  uri = URI("#{VOYAGE_API_BASE}/v1/embeddings")
  req = Net::HTTP::Post.new(uri)
  req['Content-Type'] = 'application/json'
  req['Authorization'] = "Bearer #{VOYAGE_API_KEY}"

  req.body = JSON.generate({
    model: VOYAGE_MODEL,
    input: [text],
    output_dimension: EMBEDDING_DIM
  })

  http = Net::HTTP.new(uri.hostname, uri.port)
  http.use_ssl = uri.scheme == 'https'
  http.read_timeout = 30
  response = http.request(req)

  unless response.is_a?(Net::HTTPSuccess)
    spill_log(:error, "voyage embed error: HTTP #{response.code}")
    return nil
  end

  data = JSON.parse(response.body)
  data.dig('data', 0, 'embedding')
rescue Errno::ECONNREFUSED
  spill_log(:warn, 'voyage API unreachable (connection refused)')
  nil
rescue => e
  spill_log(:error, "voyage embed failed: #{e.message}")
  nil
end

# ---------------------------------------------------------------------------
# Write
# ---------------------------------------------------------------------------

def store_entry(db, type, content, source = 'agent')
  sql_insert_returning_id(db,
    "INSERT INTO entries(type, content, source) VALUES (?, ?, ?);",
    [type, content, source])
end

def extract_triples(text)
  spill_log(:debug, "extracting triples with #{ANTHROPIC_MODEL}")
  prompt = <<~PROMPT
    Extract factual relationships from the following text as JSON.
    Return a JSON array of objects, each with "subject", "predicate", "object", and "subject_type", "object_type" fields.
    Subject and object are entity names. Predicate is the relationship.
    Types are short categories like: person, project, tool, concept, decision, date, value.
    If no clear facts can be extracted, return an empty array: []
    Return ONLY valid JSON. No explanation.

    Text: #{text}
  PROMPT

  result = call_anthropic(prompt)
  return [] if result.nil? || result.empty?

  json_str = result[/\[.*\]/m]
  return [] if json_str.nil?

  triples = JSON.parse(json_str)
  spill_log(:debug, "extracted #{triples.length} triples")
  triples
rescue JSON::ParserError
  spill_log(:error, 'failed to parse triple extraction response')
  []
end

def find_or_create_entity(db, name, type)
  existing = sql_query(db, "SELECT id FROM entities WHERE name = ? LIMIT 1;", [name])
  return existing.first['id'] unless existing.empty?

  sql_insert_returning_id(db,
    "INSERT INTO entities(name, type) VALUES (?, ?);",
    [name, type])
end

def store_triple(db, subject_name, subject_type, predicate, object_name, object_type, raw_text)
  subject_id = find_or_create_entity(db, subject_name, subject_type)
  object_id = find_or_create_entity(db, object_name, object_type)
  return if subject_id.nil? || object_id.nil?

  # Consolidation: supersede existing relations with same subject+predicate
  sql_exec(db,
    "UPDATE relations SET valid_until = datetime('now') WHERE subject_id = ? AND predicate = ? AND valid_until IS NULL;",
    [subject_id, predicate])

  relation_id = sql_insert_returning_id(db,
    "INSERT INTO relations(subject_id, predicate, object_id) VALUES (?, ?, ?);",
    [subject_id, predicate, object_id])
  return if relation_id.nil?

  sql_exec(db,
    "INSERT INTO sources(relation_id, raw_text) VALUES (?, ?);",
    [relation_id, raw_text])
end

def generate_embedding(text)
  voyage_embed(text)
end

def store_embedding(vec_db, entry_id, embedding)
  return if embedding.nil? || entry_id.nil? || vec_db.nil?
  json_vec = JSON.generate(embedding)
  # vec0 virtual tables break results_as_hash — disable it for the INSERT
  saved = vec_db.results_as_hash
  vec_db.results_as_hash = false
  vec_db.execute(
    "INSERT INTO entries_vec(rowid, embedding) VALUES (?, ?);",
    [entry_id, json_vec])
rescue SQLite3::Exception => e
  spill_log(:error, "sqlite3 error: #{e.message}")
  nil
ensure
  vec_db.results_as_hash = saved if vec_db
end

def cmd_write
  text = $stdin.read
  if text.nil? || text.strip.empty?
    spill_log(:error, 'empty input')
    exit 1
  end
  text = text.strip

  # Parse optional type prefix
  type = 'fact'
  if text.match?(/\Atype=\w+\s/)
    type = text[/\Atype=(\w+)/, 1]
    text = text.sub(/\Atype=\w+\s+/, '')
  end

  source = 'agent'
  if text.match?(/\Asource=\w+\s/)
    source = text[/\Asource=(\w+)/, 1]
    text = text.sub(/\Asource=\w+\s+/, '')
  end

  spill_log(:debug, "write: type=#{type}, #{text.length} chars")

  init_db

  db = open_db

  # Write-time dedup: exact content match (any time)
  exact_dup = db.get_first_value(
    "SELECT COUNT(*) FROM entries WHERE content = ? AND superseded_by IS NULL",
    [text]
  ).to_i
  if exact_dup > 0
    spill_log(:info, "write-time dedup: skipping exact duplicate content")
    db.close
    return
  end

  entry_id = store_entry(db, type, text, source)
  if entry_id.nil?
    spill_log(:error, 'failed to store entry')
    db.close
    exit 1
  end

  triples = extract_triples(text)
  triples.each do |triple|
    store_triple(
      db,
      triple['subject'] || 'unknown',
      triple['subject_type'] || 'concept',
      triple['predicate'] || 'related_to',
      triple['object'] || 'unknown',
      triple['object_type'] || 'concept',
      text
    )
  end
  db.close

  embedding = generate_embedding(text)
  vec_db = open_db_vec
  store_embedding(vec_db, entry_id, embedding)
  vec_db&.close

  spill_log(:info, "stored entry ##{entry_id} (#{type}), #{triples.length} triples extracted")
end

# ---------------------------------------------------------------------------
# Retrieve
# ---------------------------------------------------------------------------

STOP_WORDS = %w[a an the is are was were be been being have has had do does did
                will would shall should may might can could of in to for on with
                at by from as into about between through during before after
                and or but not no nor so yet both either neither each every all
                any few more most other some such this that these those
                i me my we our you your he him his she her it its they them their
                what which who whom how when where why if then else
                just also very too quite rather really].freeze

def extract_keywords(prompt)
  words = prompt.downcase.gsub(/[^\w\s]/, '').split
  words.reject { |w| w.length < 3 || STOP_WORDS.include?(w) }.uniq
end

def query_triples(db, keywords)
  return [] if keywords.empty?

  # Cap to avoid exceeding SQLite's expression tree depth limit (1000).
  keywords = keywords.first(50)

  like_clauses = keywords.map { "name LIKE '%' || ? || '%'" }.join(' OR ')

  sql_query(db, <<~SQL, keywords + keywords)
    SELECT
      s.name AS subject,
      r.predicate,
      o.name AS object,
      r.valid_from,
      r.valid_until
    FROM relations r
    JOIN entities s ON r.subject_id = s.id
    JOIN entities o ON r.object_id = o.id
    WHERE r.valid_until IS NULL
      AND (s.id IN (SELECT id FROM entities WHERE #{like_clauses})
           OR o.id IN (SELECT id FROM entities WHERE #{like_clauses}))
    ORDER BY r.created_at DESC
    LIMIT 20;
  SQL
end

def query_fts(db, keywords)
  return [] if keywords.empty?

  fts_query = keywords.join(' OR ')

  sql_query(db, <<~SQL, [fts_query])
    SELECT e.id, e.type, e.content, e.created_at, e.source
    FROM entries e
    JOIN entries_fts f ON e.id = f.rowid
    WHERE entries_fts MATCH ?
      AND e.superseded_by IS NULL
    ORDER BY e.created_at DESC
    LIMIT #{FTS_CANDIDATES};
  SQL
end

def query_vector(vec_db, prompt)
  return [] if vec_db.nil?

  embedding = voyage_embed(prompt)
  return [] if embedding.nil?

  json_vec = JSON.generate(embedding)
  vec_results = sql_query_vec(vec_db, <<~SQL, %w[rowid distance], [json_vec])
    SELECT rowid, distance
    FROM entries_vec
    WHERE embedding MATCH ?
    ORDER BY distance
    LIMIT #{VECTOR_CANDIDATES};
  SQL

  return [] if vec_results.empty?

  vec_results = vec_results.reject { |r| r['distance'] > VECTOR_DISTANCE_THRESHOLD }
  return [] if vec_results.empty?

  dist_by_id = {}
  vec_results.each { |r| dist_by_id[r['rowid']] = r['distance'] }

  ids = vec_results.map { |r| r['rowid'] }
  placeholders = ids.map { '?' }.join(',')
  entries = sql_query(vec_db,
    "SELECT id, type, content, created_at, source FROM entries WHERE id IN (#{placeholders}) AND superseded_by IS NULL;",
    ids)

  entries.each { |e| e['distance'] = dist_by_id[e['id']] }
  entries.sort_by { |e| e['distance'] || Float::INFINITY }
end

def rrf_merge(fts_entries, vector_entries, k: RRF_K, limit: RRF_LIMIT)
  scores = Hash.new(0.0)
  entry_by_id = {}

  fts_entries.each_with_index do |entry, rank|
    id = entry['id']
    scores[id] += 1.0 / (k + rank + 1)
    entry_by_id[id] = entry
  end

  vector_entries.each_with_index do |entry, rank|
    id = entry['id']
    scores[id] += 1.0 / (k + rank + 1)
    entry_by_id[id] ||= entry
  end

  sorted = scores.sort_by { |_id, score| -score }
  sorted.first(limit).map { |id, _score| entry_by_id[id] }
end

def format_datetime(datetime_str)
  return nil if datetime_str.nil? || datetime_str.empty?
  # SQLite stores "YYYY-MM-DD HH:MM:SS" — convert to ISO 8601 UTC
  datetime_str.sub(' ', 'T') + 'Z'
rescue
  nil
end

def format_triples(triples)
  return '' if triples.empty?
  sorted = triples.sort_by { |t| t['valid_from'] || '' }.reverse
  lines = sorted.map do |t|
    since = format_datetime(t['valid_from'])
    since_str = since ? " (since #{since})" : ''
    "- #{t['subject']} → #{t['predicate']} → #{t['object']}#{since_str}"
  end
  "## Known facts\n\n#{lines.join("\n")}"
end

def format_entries(entries)
  return '' if entries.empty?
  lines = entries.map do |e|
    date = format_datetime(e['created_at'])
    prefix = date ? "#{date} #{e['type']} #{e['source'] || 'agent'}" : "#{e['type']} #{e['source'] || 'agent'}"
    "- [#{prefix}] #{e['content']}"
  end
  "## Memory entries\n\n#{lines.join("\n")}"
end

def format_connected(entries)
  return '' if entries.empty?
  lines = entries.map do |e|
    date = format_datetime(e['created_at'])
    prefix = date ? "#{date} #{e['type']} #{e['source'] || 'agent'}" : "#{e['type']} #{e['source'] || 'agent'}"
    "- [#{prefix}] #{e['content']}"
  end
  "## Connected memories\n\n#{lines.join("\n")}"
end

def format_directives(entries)
  return '' if entries.empty?
  lines = entries.map { |e| "- #{e['content']}" }
  "## Active directives\n\n#{lines.join("\n")}"
end

def cross_encoder_rerank(prompt, entries)
  return entries if entries.empty?

  threads = entries.map { |entry|
    Thread.new {
      score = rerank_score(prompt, entry['content'])
      entry.merge('rerank_score' => score)
    }
  }
  scored = threads.map(&:value)

  # Fail-open: if no entry could be scored (API unavailable), return all entries unfiltered
  if scored.none? { |e| e['rerank_score'] > 0.0 }
    spill_log(:debug, "rerank: no scores obtained, returning entries unfiltered")
    return entries.first(RERANK_LIMIT)
  end

  scored.select { |e| e['rerank_score'] > RERANK_THRESHOLD }
        .sort_by { |e| -e['rerank_score'] }
        .first(RERANK_LIMIT)
rescue => e
  spill_log(:error, "rerank failed: #{e.message}")
  entries.first(RERANK_LIMIT)
end

def rerank_score(prompt, document)
  rerank_prompt = "Judge whether the Document is relevant to the Query. " \
    "Answer exactly \"yes\" or \"no\", nothing else.\n\n" \
    "Query: #{prompt}\n\nDocument: #{document}"

  result = call_anthropic(rerank_prompt, max_tokens: 1)
  return 0.0 if result.nil?

  answer = result.strip.downcase
  score = answer.start_with?('yes') ? 1.0 : 0.0
  spill_log(:debug, "rerank score=#{score.round(3)} for: #{document[0, 80]}")
  score
rescue => e
  spill_log(:error, "rerank_score failed: #{e.message}")
  0.0
end

def truncate(text, max_chars)
  return text if text.length <= max_chars
  text[0, max_chars] + "\n\n[truncated — #{TOKEN_BUDGET} token budget exceeded]"
end

def update_last_retrieved(db, entry_ids)
  return if entry_ids.empty?
  entry_ids.each do |id|
    sql_exec(db,
      "UPDATE entries SET last_retrieved_at = datetime('now'), retrieval_count = COALESCE(retrieval_count, 0) + 1 WHERE id = ?;",
      [id])
  end
end

def cmd_retrieve
  raw = $stdin.read
  exit 0 if raw.nil? || raw.strip.empty?
  parsed = JSON.parse(raw) rescue nil
  prompt = if parsed.is_a?(Hash)
             parsed['prompt'] || parsed.dig('tool_input', 'command') || raw
           else
             raw
           end
  exit 0 unless db_exists?
  prompt = prompt.strip

  keywords = extract_keywords(prompt)
  spill_log(:debug, "retrieve: #{keywords.length} keywords: #{keywords.first(10).join(', ')}")
  exit 0 if keywords.empty?

  db = open_db
  run_migrations(db)
  vec_db = open_db_vec
  if vec_db
    run_migrations(vec_db)
  end

  channel = ENV['CRIB_CHANNEL']
  case channel
  when 'triples'
    triples = query_triples(db, keywords)
    entries = []
    vector_entries = []
  when 'fts'
    triples = []
    entries = query_fts(db, keywords)
    vector_entries = []
  when 'vector'
    triples = []
    entries = []
    vector_entries = query_vector(vec_db, prompt)
  else
    triples = query_triples(db, keywords)
    entries = query_fts(db, keywords)
    vector_entries = query_vector(vec_db, prompt)
  end

  spill_log(:debug, "retrieve: #{triples.length} triples, #{entries.length} fts, #{vector_entries.length} vector")

  all_entries = if entries.any? && vector_entries.any?
                  rrf_merge(entries, vector_entries)
                elsif entries.any?
                  entries.first(RRF_LIMIT)
                elsif vector_entries.any?
                  vector_entries.first(RRF_LIMIT)
                else
                  []
                end

  spill_log(:debug, "retrieve: #{all_entries.length} entries after RRF merge")
  all_entries = cross_encoder_rerank(prompt, all_entries) if all_entries.any?
  spill_log(:debug, "retrieve: #{all_entries.length} entries after rerank")

  # --- Connection-aware graph expansion ---
  connected_entries = []
  begin
    if all_entries.any?
      top_ids = all_entries.map { |e| e['id'] }.compact.first(5)
      unless top_ids.empty?
        placeholders = top_ids.map { '?' }.join(',')
        conn_rows = sql_query(db, <<~SQL, top_ids + top_ids)
          SELECT entry_id_a, entry_id_b, relationship, strength
          FROM connections
          WHERE entry_id_a IN (#{placeholders}) OR entry_id_b IN (#{placeholders})
          ORDER BY strength DESC
          LIMIT #{CONNECTION_EXPANSION_LIMIT};
        SQL

        connected_ids = conn_rows.flat_map { |r| [r['entry_id_a'], r['entry_id_b']] }
                                 .uniq - top_ids
        unless connected_ids.empty?
          cp = connected_ids.map { '?' }.join(',')
          connected_entries = sql_query(db,
            "SELECT id, type, content, created_at, source FROM entries WHERE id IN (#{cp}) AND superseded_by IS NULL;",
            connected_ids)
        end
      end
    end
  rescue => e
    spill_log(:error, "connection expansion failed: #{e.message}")
  end

  # Dispositional: surface preferences that pass the reranker for this query
  # Only inject when running all channels (no channel isolation)
  pref_entries = []
  unless channel
    pref_limit = PREF_LIMIT
    pref_entries = sql_query(db,
      "SELECT id, type, content, created_at, source FROM entries " \
      "WHERE type = 'directive' AND superseded_by IS NULL " \
      "ORDER BY created_at DESC LIMIT ?;",
      [pref_limit])
    existing_ids = all_entries.map { |e| e['id'] }
    pref_entries.reject! { |p| existing_ids.include?(p['id']) }
    pref_entries = cross_encoder_rerank(prompt, pref_entries) if pref_entries.any?
  end

  # Track access times on returned entries + preference entries
  retrieved_ids = all_entries.map { |e| e['id'] }.compact
  update_last_retrieved(db, retrieved_ids + pref_entries.map { |e| e['id'] }.compact)

  db.close
  vec_db&.close

  triples_text = format_triples(triples)
  entries_text = format_entries(all_entries)
  connected_text = format_connected(connected_entries)
  prefs_text = format_directives(pref_entries)

  combined = [triples_text, entries_text, connected_text, prefs_text].reject(&:empty?).join("\n\n")
  exit 0 if combined.empty?

  combined = truncate(combined, CHAR_BUDGET)

  puts "<system-reminder>\n#{combined}\n</system-reminder>"
end

# ---------------------------------------------------------------------------
# Maintain
# ---------------------------------------------------------------------------

def classify_contradiction(content_a, content_b)
  classify_bin = File.join(SCREEN_HOME, 'bin', 'classify')
  return nil unless File.executable?(classify_bin)

  input = JSON.generate({
    'condition' => 'These two statements contradict each other (they make incompatible claims about the same topic).',
    'content' => "Statement A: #{content_a}\n\nStatement B: #{content_b}"
  })

  stdout, status = Open3.capture2(classify_bin, stdin_data: input)
  return nil unless status.success?
  stdout.strip.downcase
rescue Errno::ENOENT
  spill_log(:warn, 'classify not found, skipping contradiction detection')
  nil
rescue => e
  spill_log(:error, "classify failed: #{e.message}")
  nil
end

def cmd_maintain
  dry_run = ARGV.include?('--dry-run')
  spill_log(:debug, "maintain: dry_run=#{dry_run}")

  unless db_exists?
    puts JSON.generate({ contradictions_found: 0, corrections_linked: 0, stale_count: 0, supersessions_applied: 0, decayed_count: 0, consolidations_generated: 0, connections_discovered: 0, dry_run: dry_run, min_decay_score: 1.0 })
    exit 0
  end

  db = open_db
  run_migrations(db)

  contradictions_found = 0
  corrections_linked = 0
  supersessions_applied = 0
  stale_count = 0

  # --- Contradiction detection ---
  # Compare recent entries pairwise via FTS5 similarity. For each pair
  # with matching terms, call classify to confirm a contradiction.
  begin
    recent = sql_query(db,
      "SELECT id, content FROM entries WHERE superseded_by IS NULL ORDER BY created_at DESC LIMIT 50;")

    recent.each_with_index do |entry_a, i|
      keywords_a = extract_keywords(entry_a['content'])
      next if keywords_a.empty?

      fts_query = keywords_a.first(5).join(' OR ')
      similar = sql_query(db, <<~SQL, [fts_query, entry_a['id']])
        SELECT e.id, e.content, e.created_at
        FROM entries e
        JOIN entries_fts f ON e.id = f.rowid
        WHERE entries_fts MATCH ?
          AND e.id != ?
          AND e.superseded_by IS NULL
        ORDER BY e.created_at DESC
        LIMIT 5;
      SQL

      similar.each do |entry_b|
        answer = classify_contradiction(entry_a['content'], entry_b['content'])
        next unless answer == 'yes'

        contradictions_found += 1

        # Supersede the older entry
        older, newer = [entry_a, entry_b].sort_by { |e| e['created_at'] || '' }
        sql_exec(db,
          "UPDATE entries SET superseded_by = ? WHERE id = ? AND superseded_by IS NULL;",
          [newer['id'], older['id']])
        supersessions_applied += 1
      end
    end
  rescue => e
    spill_log(:error, "contradiction detection failed: #{e.message}")
  end

  # --- Correction linking ---
  # Find type=correction entries without a supersession link, then find
  # the original entry being corrected via vector search.
  begin
    corrections = sql_query(db,
      "SELECT id, content FROM entries WHERE type = 'lesson' AND superseded_by IS NULL;")

    vec_db = open_db_vec

    corrections.each do |correction|
      embedding = voyage_embed(correction['content'])
      next if embedding.nil? || vec_db.nil?

      json_vec = JSON.generate(embedding)
      candidates = sql_query_vec(vec_db, <<~SQL, %w[rowid distance], [json_vec])
        SELECT rowid, distance
        FROM entries_vec
        WHERE embedding MATCH ?
        ORDER BY distance
        LIMIT 5;
      SQL

      candidates = candidates.reject { |c| c['rowid'] == correction['id'] }
      next if candidates.empty?

      # Find the closest non-correction entry that is not already superseded
      candidate_ids = candidates.map { |c| c['rowid'] }
      placeholders = candidate_ids.map { '?' }.join(',')
      originals = sql_query(db,
        "SELECT id FROM entries WHERE id IN (#{placeholders}) AND type != 'correction' AND superseded_by IS NULL;",
        candidate_ids)

      next if originals.empty?

      # Supersede the closest original
      original_id = originals.first['id']
      sql_exec(db,
        "UPDATE entries SET superseded_by = ? WHERE id = ? AND superseded_by IS NULL;",
        [correction['id'], original_id])
      corrections_linked += 1
      supersessions_applied += 1
    end

    vec_db&.close
  rescue => e
    spill_log(:error, "correction linking failed: #{e.message}")
  end

  # --- Staleness tracking ---
  begin
    stale = sql_query(db, <<~SQL, [STALENESS_DAYS])
      SELECT COUNT(*) AS cnt FROM entries
      WHERE superseded_by IS NULL
        AND last_retrieved_at IS NOT NULL
        AND last_retrieved_at < datetime('now', '-' || ? || ' days');
    SQL
    stale_count = stale.first&.[]('cnt') || 0
  rescue => e
    spill_log(:error, "staleness check failed: #{e.message}")
  end

  # --- Generative consolidation ---
  consolidations_generated = 0
  connections_discovered = 0
  begin
    # Ensure consolidation tables exist
    db.execute_batch(CONSOLIDATION_SCHEMA)

    unconsolidated = sql_query(db, <<~SQL)
      SELECT id, type, content, created_at, source
      FROM entries
      WHERE superseded_by IS NULL AND consolidated_at IS NULL
      ORDER BY created_at DESC LIMIT 50;
    SQL

    if unconsolidated.length >= CONSOLIDATION_MIN_ENTRIES
      batches = unconsolidated.each_slice(CONSOLIDATION_BATCH_SIZE).first(CONSOLIDATION_MAX_BATCHES)

      batches.each do |batch|
        next if batch.length < CONSOLIDATION_MIN_ENTRIES

        entries_text = batch.map { |e|
          "ID: #{e['id']} | Type: #{e['type']} | Date: #{e['created_at']} | Content: #{e['content']}"
        }.join("\n")

        consolidation_prompt = <<~PROMPT
          Analyze these memory entries and identify:
          1. Cross-cutting patterns or insights that synthesize understanding across multiple entries
          2. Pairs of entries that are meaningfully connected (share a topic, build on each other, or represent related decisions)

          Entries:
          #{entries_text}

          Return JSON only, no explanation:
          {"insights": ["insight text here"], "connections": [{"ids": [3, 7], "relationship": "description"}]}

          If nothing meaningful, return: {"insights": [], "connections": []}
        PROMPT

        result = dry_run ? nil : call_anthropic(consolidation_prompt, max_tokens: 1024)
        if result
          json_str = result[/\{.*\}/m]
          if json_str
            parsed = JSON.parse(json_str) rescue nil
            if parsed
              vec_db_consol = nil

              # Process insights
              (parsed['insights'] || []).each do |insight_text|
                next if insight_text.nil? || insight_text.strip.empty?

                source_ids = batch.map { |e| e['id'] }

                # Insert provenance record
                consol_id = sql_insert_returning_id(db,
                  "INSERT INTO consolidations(content, source_entry_ids) VALUES (?, ?);",
                  [insight_text, JSON.generate(source_ids)])

                # Insert as an entry (type=insight, source=consolidation)
                entry_id = store_entry(db, 'insight', insight_text, 'consolidation')
                if entry_id
                  consolidations_generated += 1

                  # Generate embedding
                  embedding = generate_embedding(insight_text)
                  if embedding
                    vec_db_consol ||= open_db_vec
                    store_embedding(vec_db_consol, entry_id, embedding)
                  end

                  # Extract and store triples
                  triples = extract_triples(insight_text)
                  triples.each do |triple|
                    store_triple(db,
                      triple['subject'] || 'unknown', triple['subject_type'] || 'concept',
                      triple['predicate'] || 'related_to',
                      triple['object'] || 'unknown', triple['object_type'] || 'concept',
                      insight_text)
                  end
                end
              end

              vec_db_consol&.close

              # Process connections
              (parsed['connections'] || []).each do |conn|
                ids = conn['ids']
                next unless ids.is_a?(Array) && ids.length == 2
                a, b = ids.map(&:to_i).sort
                next if a == b || a <= 0 || b <= 0
                relationship = conn['relationship'] || 'related'

                existing = sql_query(db,
                  "SELECT id FROM connections WHERE entry_id_a = ? AND entry_id_b = ?", [a, b])
                if existing.empty?
                  sql_exec(db,
                    "INSERT INTO connections(entry_id_a, entry_id_b, relationship) VALUES (?, ?, ?);",
                    [a, b, relationship])
                else
                  sql_exec(db,
                    "UPDATE connections SET strength = strength + 1.0 WHERE entry_id_a = ? AND entry_id_b = ?;",
                    [a, b])
                end
                connections_discovered += 1
              end
            end
          end
        end

        # Mark batch entries as consolidated
        unless dry_run
          batch_ids = batch.map { |e| e['id'] }
          placeholders = batch_ids.map { '?' }.join(',')
          sql_exec(db,
            "UPDATE entries SET consolidated_at = datetime('now') WHERE id IN (#{placeholders});",
            batch_ids)
        end
      end
    end
  rescue => e
    spill_log(:error, "consolidation failed: #{e.message}")
  end

  # --- Ebbinghaus decay pruning (disabled by default) ---
  decayed_count = 0
  min_decay = 1.0
  if DECAY_ENABLED
    begin
      active_entries = sql_query(db,
        "SELECT id, type, created_at, last_retrieved_at, COALESCE(retrieval_count, 0) as rc " \
        "FROM entries WHERE superseded_by IS NULL AND created_at < datetime('now', '-' || ? || ' days')",
        [GRACE_PERIOD_DAYS])

      active_entries.each do |entry|
        last_access = entry['last_retrieved_at'] || entry['created_at']
        elapsed = (Time.now.utc - Time.parse(last_access)).to_f / 86400.0
        base_hl = HALF_LIFE.fetch(entry['type'], HALF_LIFE['fact'])
        eff_hl = base_hl * (1.0 + RETRIEVAL_BOOST * Math.log(1.0 + entry['rc']))
        decay = Math.exp(-elapsed * Math.log(2) / eff_hl)
        min_decay = decay if decay < min_decay

        if decay < DECAY_ARCHIVE_THRESHOLD
          spill_log(:debug, "decay: archiving entry ##{entry['id']} (score=#{decay.round(4)}, type=#{entry['type']})")
          unless dry_run
            sql_exec(db, "UPDATE entries SET superseded_by = -1 WHERE id = ? AND superseded_by IS NULL", [entry['id']])
          end
          decayed_count += 1
        end
      end
    rescue => e
      spill_log(:error, "decay pruning failed: #{e.message}")
    end
  end

  db.close

  result = {
    contradictions_found: contradictions_found,
    corrections_linked: corrections_linked,
    stale_count: stale_count,
    supersessions_applied: supersessions_applied,
    decayed_count: decayed_count,
    consolidations_generated: consolidations_generated,
    connections_discovered: connections_discovered,
    dry_run: dry_run,
    min_decay_score: min_decay.round(4)
  }

  spill_log(:info, "maintain complete", **result)
  puts JSON.generate(result)
  exit 0
end

# ---------------------------------------------------------------------------
# Hints
# ---------------------------------------------------------------------------

def cmd_hints
  raw = $stdin.read
  exit 0 if raw.nil? || raw.strip.empty?
  exit 0 unless db_exists?
  prompt = raw.strip

  keywords = extract_keywords(prompt)
  exit 0 if keywords.empty?

  db = open_db
  run_migrations(db)

  # FTS5 results
  fts_results = query_fts(db, keywords)

  # Triple results — gather subjects as topic clusters
  triple_results = query_triples(db, keywords)

  # Group FTS results by shared entities/subjects
  clusters = Hash.new { |h, k| h[k] = [] }

  # Cluster FTS entries by matching keywords
  fts_results.each do |entry|
    entry_kw = extract_keywords(entry['content'])
    topic = (entry_kw & keywords).first || entry_kw.first || 'general'
    clusters[topic] << entry
  end

  # Cluster triples by subject
  triple_results.each do |triple|
    subject = triple['subject'] || 'general'
    clusters[subject] << triple
  end

  # Also check for directives
  directive_results = sql_query(db,
    "SELECT id, type, content FROM entries WHERE type = 'directive' AND superseded_by IS NULL;")
  directive_results.each do |d|
    d_kw = extract_keywords(d['content'])
    if (d_kw & keywords).any?
      clusters['directive:' + (d_kw & keywords).first] << d
    end
  end

  db.close

  # Emit hints, capped
  hints = []
  clusters.each do |topic, items|
    count = items.length
    next if count == 0

    # Check if this is a directive cluster
    if topic.start_with?('directive:')
      hints << "You have a standing directive about #{topic.sub('directive:', '')}."
    elsif count == 1
      hints << "You have a stored memory about #{topic}."
    else
      hints << "You have #{count} stored memories about #{topic}."
    end
  end

  hints.first(HINTS_CAP).each { |h| puts h }
rescue => e
  spill_log(:error, "hints failed: #{e.message}")
  exit 0
end

# ---------------------------------------------------------------------------
# Init / Schema
# ---------------------------------------------------------------------------

def cmd_init
  init_db
  spill_log(:info, "initialized #{DB_PATH}")
end

def cmd_doctor
  report = {}

  # Ruby
  report['ruby'] = { 'version' => RUBY_VERSION, 'ok' => true }

  # sqlite3 gem
  report['sqlite3_gem'] = {
    'version' => SQLite3::VERSION,
    'ok' => true
  }

  # sqlite-vec extension
  begin
    vec_db = SQLite3::Database.new(':memory:')
    vec_db.enable_load_extension(true)
    vec_db.load_extension(VEC_EXTENSION)
    vec_version = vec_db.execute('SELECT vec_version();').first.first
    vec_db.close
    report['sqlite_vec'] = {
      'path' => VEC_EXTENSION,
      'version' => vec_version,
      'ok' => true
    }
  rescue => e
    report['sqlite_vec'] = {
      'path' => VEC_EXTENSION,
      'version' => nil,
      'ok' => false,
      'error' => e.message
    }
  end

  # Anthropic API key
  has_anthropic = !ANTHROPIC_API_KEY.nil? && !ANTHROPIC_API_KEY.empty?
  report['anthropic_api_key'] = { 'ok' => has_anthropic }
  report['anthropic_api_key']['error'] = 'ANTHROPIC_API_KEY not set' unless has_anthropic

  # Voyage API key
  has_voyage = !VOYAGE_API_KEY.nil? && !VOYAGE_API_KEY.empty?
  report['voyage_api_key'] = { 'ok' => has_voyage }
  report['voyage_api_key']['error'] = 'VOYAGE_API_KEY not set' unless has_voyage

  # Database
  report['database'] = {
    'path' => DB_PATH,
    'exists' => File.exist?(DB_PATH)
  }

  # Probe
  if ARGV.include?('--probe')
    begin
      require 'tmpdir'
      probe_db = File.join(Dir.tmpdir, "crib-probe-#{$$}.db")
      probe_env = { 'CRIB_DB' => probe_db }
      Open3.capture2e(probe_env, 'ruby', __FILE__, 'init')
      Open3.capture2e(probe_env, 'ruby', __FILE__, 'write', stdin_data: 'type=note doctor probe test')
      output, = Open3.capture2(probe_env.merge('CRIB_CHANNEL' => 'fts'), 'ruby', __FILE__, 'retrieve',
        stdin_data: 'doctor probe test', err: File::NULL)
      has_xml = output.include?('<system-reminder>')
      report['probe'] = { 'ok' => true }
      report['probe']['warn'] = 'retrieve output missing expected XML shape' unless has_xml
    rescue => e
      report['probe'] = { 'ok' => true, 'warn' => "probe error: #{e.message}" }
    ensure
      FileUtils.rm_f(probe_db) if probe_db
    end
  end

  # Overall
  report['protocol_version'] = 1
  report['ok'] = report.values.all? { |v| v.is_a?(Hash) ? v['ok'] != false : true }

  puts JSON.pretty_generate(report)
  exit(report['ok'] ? 0 : 1)
end

# ---------------------------------------------------------------------------
# Migrate
# ---------------------------------------------------------------------------

def cmd_migrate
  unless db_exists?
    spill_log(:info, "no database to migrate")
    exit 0
  end

  db = open_db
  run_migrations(db)

  type_map = {
    'note'       => 'fact',
    'decision'   => 'fact',
    'preference' => 'directive',
    'interest'   => 'fact',
    'correction' => 'lesson',
    'error'      => 'lesson',
    'reasoning'  => 'lesson',
    'reflection' => 'lesson',
  }

  type_map.each do |old_type, new_type|
    sql_exec(db, "UPDATE entries SET type = ? WHERE type = ?", [new_type, old_type])
    count = db.changes rescue 0
    spill_log(:info, "migrate: #{old_type} → #{new_type}: #{count} entries")
  end

  # Set source='agent' on any entries that have NULL or empty source
  sql_exec(db, "UPDATE entries SET source = 'agent' WHERE source IS NULL OR source = ''")

  db.close
  spill_log(:info, "migration complete")
end

# ---------------------------------------------------------------------------
# Sync
# ---------------------------------------------------------------------------

def kebab_case(text, max_len = 50)
  text.downcase
      .gsub(/[^a-z0-9\s-]/, '')
      .strip
      .gsub(/\s+/, '-')
      .slice(0, max_len)
      .sub(/-+\z/, '')
end

def find_related(db, entry_id, keywords, limit = 5)
  return [] if keywords.empty?
  fts_query = keywords.first(5).join(' OR ')
  results = sql_query(db, <<~SQL, [fts_query, entry_id, limit])
    SELECT e.id, e.type, e.content
    FROM entries e
    JOIN entries_fts f ON e.id = f.rowid
    WHERE entries_fts MATCH ?
      AND e.id != ?
      AND e.superseded_by IS NULL
    ORDER BY e.created_at DESC
    LIMIT ?;
  SQL
  results.map { |r| kebab_case(r['content']) + '.md' }
end

def cmd_sync
  unless db_exists?
    spill_log(:info, "no database to sync")
    exit 0
  end

  db = open_db
  run_migrations(db)

  entries = sql_query(db, <<~SQL)
    SELECT id, type, content, created_at, last_retrieved_at, source,
           COALESCE(retrieval_count, 0) as retrieval_count
    FROM entries
    WHERE superseded_by IS NULL
    ORDER BY created_at DESC;
  SQL

  staleness_threshold = Time.now.utc - (STALENESS_DAYS * 86400)

  tag_counts = Hash.new(0)
  entries.each { |e| tag_counts[e['type']] += 1 }

  tmp_dir = "#{KNOWLEDGE_DIR}.tmp.#{$$}"
  FileUtils.rm_rf(tmp_dir)
  FileUtils.mkdir_p(tmp_dir)

  index_lines = []
  index_lines << "# Knowledge Index"
  index_lines << ""
  index_lines << "_Generated: #{Time.now.utc.strftime('%Y-%m-%dT%H:%M:%SZ')}_"
  index_lines << ""

  stale_entries = entries.select do |e|
    last = e['last_retrieved_at'] || e['created_at']
    last && Time.parse(last) < staleness_threshold
  end
  unless stale_entries.empty?
    index_lines << "## Staleness warnings"
    index_lines << ""
    stale_entries.first(10).each do |e|
      index_lines << "- **#{kebab_case(e['content'])}** — not accessed in #{STALENESS_DAYS}+ days"
    end
    index_lines << "- _(#{stale_entries.length - 10} more)_" if stale_entries.length > 10
    index_lines << ""
  end

  all_types = %w[fact lesson directive]
  low_types = all_types.select { |t| tag_counts[t].to_i < 3 }
  unless low_types.empty?
    index_lines << "## Coverage gaps"
    index_lines << ""
    low_types.each { |t| index_lines << "- `#{t}` has only #{tag_counts[t].to_i} entries" }
    index_lines << ""
  end

  operator_entries = entries.select { |e| e['source'] == 'operator' }
  agent_entries = entries.select { |e| e['source'] == 'agent' }
  conflicts = []
  operator_entries.each do |op|
    op_kw = extract_keywords(op['content']).first(3)
    next if op_kw.empty?
    agent_entries.each do |ag|
      ag_kw = extract_keywords(ag['content']).first(3)
      if (op_kw & ag_kw).length >= 2
        conflicts << { operator: op, agent: ag }
      end
    end
  end
  unless conflicts.empty?
    index_lines << "## Potential conflicts (operator vs agent)"
    index_lines << ""
    conflicts.first(5).each do |c|
      index_lines << "- operator: #{c[:operator]['content'][0,60]}..."
      index_lines << "  agent: #{c[:agent]['content'][0,60]}..."
    end
    index_lines << ""
  end

  index_lines << "## Entries"
  index_lines << ""
  index_lines << "| File | Type | Source | Created |"
  index_lines << "|------|------|--------|---------|"

  entries.each do |entry|
    filename = "#{kebab_case(entry['content'])}.md"
    base = filename
    counter = 1
    while File.exist?(File.join(tmp_dir, filename))
      filename = base.sub('.md', "-#{counter}.md")
      counter += 1
    end

    keywords = extract_keywords(entry['content'])
    related = find_related(db, entry['id'], keywords)
    created = format_datetime(entry['created_at']) || 'unknown'
    updated = format_datetime(entry['last_retrieved_at'] || entry['created_at']) || created

    frontmatter = []
    frontmatter << "---"
    frontmatter << "type: #{entry['type']}"
    frontmatter << "source: #{entry['source'] || 'agent'}"
    frontmatter << "created: #{created}"
    frontmatter << "updated: #{updated}"
    frontmatter << "retrieval_count: #{entry['retrieval_count']}"
    frontmatter << "related: [#{related.first(5).map { |r| "\"#{r}\"" }.join(', ')}]" unless related.empty?
    frontmatter << "---"

    body = "#{frontmatter.join("\n")}\n\n#{entry['content']}\n"
    File.write(File.join(tmp_dir, filename), body)

    source = entry['source'] || 'agent'
    index_lines << "| #{filename} | #{entry['type']} | #{source} | #{created} |"
  end

  File.write(File.join(tmp_dir, '_index.md'), index_lines.join("\n") + "\n")

  FileUtils.rm_rf(KNOWLEDGE_DIR)
  FileUtils.mv(tmp_dir, KNOWLEDGE_DIR)

  db.close
  spill_log(:info, "synced #{entries.length} entries to #{KNOWLEDGE_DIR}")
end

# ---------------------------------------------------------------------------
# Correct
# ---------------------------------------------------------------------------

def cmd_correct
  text = $stdin.read
  if text.nil? || text.strip.empty?
    spill_log(:error, 'empty input')
    exit 1
  end
  text = text.strip

  type = 'fact'
  if text.match?(/\Atype=\w+\s/)
    type = text[/\Atype=(\w+)/, 1]
    text = text.sub(/\Atype=\w+\s+/, '')
  end

  init_db

  db = open_db
  entry_id = store_entry(db, type, text, 'operator')
  if entry_id.nil?
    spill_log(:error, 'failed to store correction')
    db.close
    exit 1
  end

  triples = extract_triples(text)
  triples.each do |triple|
    store_triple(db, triple['subject'] || 'unknown', triple['subject_type'] || 'concept',
      triple['predicate'] || 'related_to', triple['object'] || 'unknown',
      triple['object_type'] || 'concept', text)
  end
  db.close

  embedding = generate_embedding(text)
  vec_db = open_db_vec
  store_embedding(vec_db, entry_id, embedding)
  vec_db&.close

  spill_log(:info, "stored operator entry ##{entry_id} (#{type})")
end

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

def usage
  $stderr.puts <<~USAGE
    Usage: crib <command>

    Commands:
      write     Store text and extracted fact triples (stdin)
      retrieve  Query memory for relevant context (stdin)
      hints     Return lightweight topic-level nudges for injection (stdin)
      init      Initialize the database
      doctor    Check prerequisites and report status (JSON)
      maintain  Run maintenance: correction linking, contradiction detection,
                staleness tracking, consolidation, connection discovery (JSON)
      migrate   Remap old entry types to fact/lesson/directive
      sync      Export entries to knowledge directory as Markdown files
      correct   Store an operator correction (stdin, sets source=operator)

    Environment:
      CRIB_DB        Path to SQLite database (default: .state/crib/crib.db)
      CRIB_LOG_LEVEL Minimum log level: debug, info, warn, error (default: warn)
  USAGE
  exit 1
end

def cmd_migrate_embeddings
  unless db_exists?
    spill_log(:info, "no database to migrate embeddings")
    exit 0
  end

  unless VOYAGE_API_KEY
    spill_log(:error, "VOYAGE_API_KEY is required for embedding migration")
    exit 1
  end

  db = open_db
  run_migrations(db)

  entries = sql_query(db, "SELECT id, content FROM entries WHERE superseded_by IS NULL;")
  spill_log(:info, "migrate-embeddings: #{entries.length} entries to re-embed")

  vec_db = open_db_vec
  unless vec_db
    spill_log(:error, "cannot open vec database")
    db.close
    exit 1
  end

  # Drop and recreate vec table with new dimension
  begin
    vec_db.execute("DROP TABLE IF EXISTS entries_vec;")
    vec_db.execute_batch(VEC_SCHEMA)
  rescue SQLite3::Exception => e
    spill_log(:error, "failed to recreate vec table: #{e.message}")
    db.close
    vec_db.close
    exit 1
  end

  embedded = 0
  entries.each do |entry|
    embedding = voyage_embed(entry['content'])
    if embedding
      store_embedding(vec_db, entry['id'], embedding)
      embedded += 1
    end
    spill_log(:info, "migrate-embeddings: #{embedded}/#{entries.length}") if embedded % 50 == 0
  end

  db.close
  vec_db.close
  spill_log(:info, "migrate-embeddings: complete — #{embedded}/#{entries.length} entries re-embedded")
end

command = ARGV.shift
case command
when 'write'             then cmd_write
when 'retrieve'          then cmd_retrieve
when 'hints'             then cmd_hints
when 'init'              then cmd_init
when 'doctor'            then cmd_doctor
when 'maintain'          then cmd_maintain
when 'migrate'           then cmd_migrate
when 'migrate-embeddings' then cmd_migrate_embeddings
when 'sync'              then cmd_sync
when 'correct'           then cmd_correct
else usage
end
